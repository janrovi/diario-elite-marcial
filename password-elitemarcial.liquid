<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="El Diario de Entrenamiento para artes marciales más completo llega pronto. Sesiones, estadísticas, cinturón, biometría y mucho más.">
  <meta property="og:title" content="Élite Marcial — El Diario de Entrenamiento">
  <meta property="og:description" content="El arma que le faltaba al guerrero moderno. Próximamente.">
  <meta property="og:image" content="https://cdn.shopify.com/s/files/1/1049/1966/2933/files/Elite_Marcial_3D_Metallic_Shield_Logo.png?v=1780514126">
  <meta name="twitter:card" content="summary_large_image">
  <title>Élite Marcial — El Diario de Entrenamiento</title>
  {{ content_for_header }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --red: #C41A1A;
      --red-light: #ef4444;
      --gold: #f59e0b;
      --bg: #080808;
      --card: #0f0f0f;
      --card2: #141414;
      --border: #1c1c1c;
      --border2: #252525;
      --text: #ffffff;
      --muted: #888888;
      --faint: #444444;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    /* ── Ambient background ── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse 900px 600px at 15% 10%, rgba(196,26,26,0.09) 0%, transparent 70%),
        radial-gradient(ellipse 600px 400px at 85% 85%, rgba(245,158,11,0.05) 0%, transparent 70%),
        radial-gradient(ellipse 400px 300px at 50% 50%, rgba(196,26,26,0.03) 0%, transparent 70%);
      pointer-events: none;
      z-index: 0;
    }

    /* ── Scroll animations ── */
    .reveal {
      opacity: 0;
      transform: translateY(32px);
      transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1), transform 0.8s cubic-bezier(0.16,1,0.3,1);
    }
    .reveal.visible {
      opacity: 1;
      transform: none;
    }
    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }
    .reveal-delay-4 { transition-delay: 0.4s; }
    .reveal-delay-5 { transition-delay: 0.5s; }
    .reveal-delay-6 { transition-delay: 0.6s; }

    /* ── Container ── */
    .container {
      position: relative;
      z-index: 1;
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 32px;
    }

    /* ══════════════════════════════
       HERO
    ══════════════════════════════ */
    .hero {
      position: relative;
      z-index: 1;
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding: 100px 32px 80px;
      max-width: 1100px;
      margin: 0 auto;
      gap: 60px;
    }

    .hero-left {
      flex: 1;
      min-width: 0;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(196,26,26,0.1);
      border: 1px solid rgba(196,26,26,0.3);
      border-radius: 100px;
      padding: 6px 16px 6px 10px;
      margin-bottom: 36px;
      font-size: 11px;
      font-weight: 700;
      color: #f87171;
      letter-spacing: 1px;
      text-transform: uppercase;
    }
    .badge-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: #C41A1A;
      box-shadow: 0 0 8px rgba(196,26,26,0.8);
      animation: pulse-dot 2s ease-in-out infinite;
    }
    @keyframes pulse-dot {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(0.8); opacity: 0.5; }
    }

    .eyebrow {
      font-size: 11px;
      font-weight: 700;
      color: var(--red);
      letter-spacing: 3px;
      text-transform: uppercase;
      margin-bottom: 20px;
    }

    h1 {
      font-size: clamp(44px, 5.5vw, 76px);
      font-weight: 900;
      line-height: 1.03;
      letter-spacing: -3px;
      margin-bottom: 24px;
    }
    h1 .accent {
      background: linear-gradient(135deg, #C41A1A, #ef4444);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-tagline {
      font-size: clamp(15px, 1.8vw, 18px);
      color: var(--muted);
      line-height: 1.75;
      max-width: 480px;
      margin-bottom: 44px;
      font-weight: 400;
    }

    /* Email form */
    .form-eyebrow {
      font-size: 10px;
      font-weight: 800;
      color: var(--gold);
      letter-spacing: 2.5px;
      text-transform: uppercase;
      margin-bottom: 12px;
    }
    .form-row {
      display: flex;
      gap: 10px;
      max-width: 440px;
      margin-bottom: 10px;
    }
    .form-row input[type="email"] {
      flex: 1;
      background: var(--card2);
      border: 1.5px solid var(--border2);
      border-radius: 14px;
      padding: 14px 18px;
      color: #fff;
      font-size: 15px;
      font-family: inherit;
      font-weight: 500;
      outline: none;
      transition: border-color 0.2s;
    }
    .form-row input[type="email"]:focus { border-color: var(--red); }
    .form-row input[type="email"]::placeholder { color: #3a3a3a; }
    .btn-primary {
      background: var(--red);
      border: none;
      border-radius: 14px;
      padding: 14px 24px;
      color: #fff;
      font-size: 14px;
      font-weight: 800;
      font-family: inherit;
      cursor: pointer;
      white-space: nowrap;
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
      box-shadow: 0 0 0 0 rgba(196,26,26,0.4);
    }
    .btn-primary:hover {
      background: #a81515;
      transform: translateY(-1px);
      box-shadow: 0 8px 24px rgba(196,26,26,0.35);
    }
    .form-hint { font-size: 12px; color: var(--faint); }
    .form-success {
      display: none;
      font-size: 15px;
      color: #10b981;
      font-weight: 700;
      padding: 14px 18px;
      background: rgba(16,185,129,0.08);
      border: 1px solid rgba(16,185,129,0.2);
      border-radius: 12px;
      max-width: 440px;
    }

    /* ── Phone mockup ── */
    .hero-right {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .phone-wrap {
      position: relative;
    }
    .phone-wrap::before {
      content: '';
      position: absolute;
      bottom: -40px;
      left: 50%;
      transform: translateX(-50%);
      width: 220px;
      height: 60px;
      background: radial-gradient(ellipse, rgba(196,26,26,0.35) 0%, transparent 70%);
      filter: blur(20px);
    }

    .phone {
      width: 260px;
      height: 520px;
      background: #0c0c0c;
      border-radius: 44px;
      border: 1.5px solid #2a2a2a;
      box-shadow:
        0 0 0 1px #111,
        0 40px 80px rgba(0,0,0,0.7),
        inset 0 0 0 1px rgba(255,255,255,0.04);
      position: relative;
      overflow: hidden;
    }

    .phone-island {
      position: absolute;
      top: 14px;
      left: 50%;
      transform: translateX(-50%);
      width: 90px;
      height: 26px;
      background: #000;
      border-radius: 16px;
      z-index: 10;
    }

    .phone-screen {
      padding: 56px 16px 20px;
      height: 100%;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .ps-status {
      display: flex;
      justify-content: space-between;
      font-size: 10px;
      color: #555;
      font-weight: 600;
    }

    .ps-greeting {
      padding-top: 4px;
    }
    .ps-name {
      font-size: 15px;
      font-weight: 800;
      color: #fff;
      line-height: 1.2;
    }
    .ps-date {
      font-size: 10px;
      color: #555;
      font-weight: 500;
      margin-top: 2px;
    }

    .ps-ring-wrap {
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      margin: 4px 0;
    }
    .ps-ring {
      width: 90px;
      height: 90px;
    }
    .ps-ring-label {
      position: absolute;
      text-align: center;
    }
    .ps-ring-num {
      font-size: 22px;
      font-weight: 900;
      color: #fff;
      line-height: 1;
    }
    .ps-ring-sub {
      font-size: 9px;
      color: #666;
      font-weight: 600;
    }

    .ps-card {
      background: #161616;
      border: 1px solid #222;
      border-radius: 14px;
      padding: 11px 13px;
    }
    .ps-card-label {
      font-size: 9px;
      color: #555;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 4px;
    }
    .ps-card-title {
      font-size: 13px;
      font-weight: 800;
      color: #fff;
      margin-bottom: 2px;
    }
    .ps-card-meta {
      font-size: 10px;
      color: #555;
      font-weight: 500;
    }

    .ps-stats {
      display: flex;
      gap: 8px;
    }
    .ps-stat {
      flex: 1;
      background: #161616;
      border: 1px solid #1e1e1e;
      border-radius: 12px;
      padding: 9px 8px;
      text-align: center;
    }
    .ps-stat-val {
      font-size: 15px;
      font-weight: 800;
      color: #fff;
      line-height: 1.2;
    }
    .ps-stat-key {
      font-size: 8px;
      color: #555;
      font-weight: 600;
      margin-top: 2px;
    }

    .ps-belt {
      display: flex;
      align-items: center;
      gap: 8px;
      background: #161616;
      border: 1px solid #1e1e1e;
      border-radius: 12px;
      padding: 9px 13px;
    }
    .ps-belt-bar {
      flex: 1;
      height: 5px;
      background: #222;
      border-radius: 3px;
      overflow: hidden;
    }
    .ps-belt-fill {
      width: 68%;
      height: 100%;
      background: linear-gradient(90deg, #C41A1A, #ef4444);
      border-radius: 3px;
    }
    .ps-belt-label {
      font-size: 9px;
      color: #666;
      font-weight: 700;
    }
    .ps-belt-pct {
      font-size: 10px;
      color: var(--red);
      font-weight: 800;
    }

    /* ══════════════════════════════
       FEATURES
    ══════════════════════════════ */
    .section {
      position: relative;
      z-index: 1;
      padding: 120px 0;
    }

    .section-eyebrow {
      font-size: 11px;
      font-weight: 700;
      color: var(--red);
      letter-spacing: 3px;
      text-transform: uppercase;
      margin-bottom: 20px;
      text-align: center;
    }

    .section-title {
      font-size: clamp(36px, 4.5vw, 60px);
      font-weight: 900;
      line-height: 1.07;
      letter-spacing: -2px;
      text-align: center;
      margin-bottom: 16px;
    }
    .section-title .accent {
      background: linear-gradient(135deg, #C41A1A, #ef4444);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .section-sub {
      font-size: 17px;
      color: var(--muted);
      text-align: center;
      line-height: 1.7;
      max-width: 500px;
      margin: 0 auto 72px;
      font-weight: 400;
    }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }

    .feat-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 28px 24px;
      position: relative;
      overflow: hidden;
      transition: border-color 0.3s, transform 0.3s;
    }
    .feat-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--feat-color, #C41A1A), transparent);
      opacity: 0.6;
    }
    .feat-card:hover {
      border-color: var(--border2);
      transform: translateY(-3px);
    }

    .feat-icon {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      margin-bottom: 18px;
    }
    .feat-title {
      font-size: 16px;
      font-weight: 800;
      color: #fff;
      margin-bottom: 8px;
      letter-spacing: -0.3px;
    }
    .feat-desc {
      font-size: 13px;
      color: #666;
      line-height: 1.65;
      font-weight: 400;
    }

    /* ══════════════════════════════
       QUOTE SECTION
    ══════════════════════════════ */
    .quote-section {
      position: relative;
      z-index: 1;
      padding: 100px 32px;
      text-align: center;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }

    .quote-text {
      font-size: clamp(24px, 3.5vw, 44px);
      font-weight: 800;
      line-height: 1.25;
      letter-spacing: -1.5px;
      max-width: 800px;
      margin: 0 auto 20px;
      color: #ddd;
    }
    .quote-text em {
      font-style: normal;
      background: linear-gradient(135deg, #C41A1A, #ef4444);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .quote-author {
      font-size: 13px;
      color: var(--faint);
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    /* ══════════════════════════════
       CTA FINAL
    ══════════════════════════════ */
    .cta-section {
      position: relative;
      z-index: 1;
      padding: 120px 32px;
      text-align: center;
    }

    .cta-title {
      font-size: clamp(36px, 4.5vw, 60px);
      font-weight: 900;
      line-height: 1.07;
      letter-spacing: -2px;
      margin-bottom: 20px;
    }
    .cta-sub {
      font-size: 17px;
      color: var(--muted);
      margin-bottom: 44px;
      max-width: 440px;
      margin-left: auto;
      margin-right: auto;
      line-height: 1.7;
    }

    .cta-form {
      display: flex;
      gap: 10px;
      max-width: 420px;
      margin: 0 auto 12px;
    }
    .cta-hint {
      font-size: 12px;
      color: var(--faint);
      margin-bottom: 52px;
    }

    .social {
      display: flex;
      gap: 14px;
      justify-content: center;
      margin-bottom: 52px;
    }
    .social a {
      display: flex;
      align-items: center;
      gap: 8px;
      background: var(--card2);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 10px 18px;
      color: #888;
      font-size: 13px;
      font-weight: 700;
      text-decoration: none;
      transition: color 0.2s, border-color 0.2s;
    }
    .social a:hover { color: #fff; border-color: var(--border2); }

    /* ══════════════════════════════
       FOOTER
    ══════════════════════════════ */
    .footer {
      position: relative;
      z-index: 1;
      border-top: 1px solid var(--border);
      padding: 32px;
      text-align: center;
      font-size: 12px;
      color: var(--faint);
    }

    /* ══════════════════════════════
       PASSWORD MODAL
    ══════════════════════════════ */
    .pw-trigger {
      position: fixed;
      bottom: 20px;
      right: 22px;
      font-size: 11px;
      color: #2a2a2a;
      background: none;
      border: none;
      font-family: inherit;
      cursor: pointer;
      z-index: 50;
      transition: color 0.2s;
    }
    .pw-trigger:hover { color: #555; }

    .pw-modal {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.88);
      z-index: 100;
      align-items: center;
      justify-content: center;
      backdrop-filter: blur(8px);
    }
    .pw-modal.open { display: flex; }
    .pw-box {
      background: #111;
      border: 1px solid #1e1e1e;
      border-radius: 20px;
      padding: 36px;
      width: 360px;
      max-width: 92vw;
    }
    .pw-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
    }
    .pw-header h3 { font-size: 17px; font-weight: 800; }
    .pw-close {
      background: #1e1e1e;
      border: none;
      color: #888;
      font-size: 16px;
      cursor: pointer;
      border-radius: 8px;
      width: 30px; height: 30px;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.2s;
    }
    .pw-close:hover { background: #2a2a2a; color: #fff; }
    .pw-box input[type="password"] {
      width: 100%;
      background: #0a0a0a;
      border: 1.5px solid #1e1e1e;
      border-radius: 12px;
      padding: 13px 16px;
      color: #fff;
      font-size: 15px;
      font-family: inherit;
      outline: none;
      margin-bottom: 12px;
      transition: border-color 0.2s;
    }
    .pw-box input[type="password"]:focus { border-color: var(--red); }
    .pw-box .btn-primary { width: 100%; justify-content: center; }

    /* ══════════════════════════════
       RESPONSIVE
    ══════════════════════════════ */
    @media (max-width: 880px) {
      .hero {
        flex-direction: column;
        text-align: center;
        align-items: center;
        padding: 100px 24px 60px;
      }
      .hero-left { display: flex; flex-direction: column; align-items: center; }
      .hero-tagline, .form-eyebrow { text-align: center; }
      .form-row, .cta-form { max-width: 100%; }
      .features-grid { grid-template-columns: 1fr 1fr; }
    }

    @media (max-width: 580px) {
      .features-grid { grid-template-columns: 1fr; }
      .form-row, .cta-form { flex-direction: column; }
      .form-row .btn-primary, .cta-form .btn-primary { width: 100%; }
      .social { flex-direction: column; align-items: center; }
      h1 { letter-spacing: -2px; }
    }
  </style>
</head>
<body>

  <div style="display:none">{{ content_for_layout }}</div>

  <!-- ══ HERO ══ -->
  <div style="position:relative;z-index:1;">
    <section class="hero">

      <div class="hero-left">
        <div class="badge reveal">
          <span class="badge-dot"></span>
          En desarrollo activo
        </div>

        <p class="eyebrow reveal">// Diario de Entrenamiento</p>

        <h1 class="reveal">
          El arma que le<br>
          faltaba al <span class="accent">guerrero</span><br>
          moderno.
        </h1>

        <p class="hero-tagline reveal">
          Registra cada sesión, analiza tu progreso, gestiona tu biometría
          y conecta con tu coach. Para quienes se toman en serio el camino.
        </p>

        <div class="reveal">
          <p class="form-eyebrow">✦ Sé el primero en saber cuándo llega</p>
          <div class="form-row" id="heroForm">
            <input type="email" id="heroEmail" placeholder="tu@email.com" autocomplete="email">
            <button class="btn-primary" onclick="submitEmail('heroEmail','heroForm','heroSuccess')">Avisarme</button>
          </div>
          <p class="form-hint" id="heroHint">Sin spam. Solo el aviso cuando abramos.</p>
          <p class="form-success" id="heroSuccess">✅ Apuntado. Te avisamos en cuanto abramos.</p>
        </div>
      </div>

      <!-- Phone mockup -->
      <div class="hero-right reveal">
        <div class="phone-wrap">
          <div class="phone">
            <div class="phone-island"></div>
            <div class="phone-screen">
              <div class="ps-status">
                <span>9:41</span>
                <span>▮▮▮ ●</span>
              </div>
              <div class="ps-greeting">
                <div class="ps-name">Buenas, Mario 🥋</div>
                <div class="ps-date">Sábado · 14 Jun 2026</div>
              </div>
              <div class="ps-ring-wrap">
                <svg class="ps-ring" viewBox="0 0 100 100">
                  <circle cx="50" cy="50" r="40" fill="none" stroke="#1a1a1a" stroke-width="7"/>
                  <circle cx="50" cy="50" r="40" fill="none" stroke="#C41A1A" stroke-width="7"
                    stroke-dasharray="251" stroke-dashoffset="80" stroke-linecap="round"
                    transform="rotate(-90 50 50)" style="filter:drop-shadow(0 0 6px rgba(196,26,26,0.6))"/>
                </svg>
                <div class="ps-ring-label">
                  <div class="ps-ring-num">14</div>
                  <div class="ps-ring-sub">sesiones</div>
                </div>
              </div>
              <div class="ps-card">
                <div class="ps-card-label">Última sesión</div>
                <div class="ps-card-title">BJJ · Guardia abierta</div>
                <div class="ps-card-meta">2h 15min &nbsp;·&nbsp; Ayer</div>
              </div>
              <div class="ps-stats">
                <div class="ps-stat">
                  <div class="ps-stat-val">🥋</div>
                  <div class="ps-stat-key">Azul</div>
                </div>
                <div class="ps-stat">
                  <div class="ps-stat-val">47</div>
                  <div class="ps-stat-key">técnicas</div>
                </div>
                <div class="ps-stat">
                  <div class="ps-stat-val">6</div>
                  <div class="ps-stat-key">semanas</div>
                </div>
              </div>
              <div class="ps-belt">
                <div class="ps-belt-label">Próximo cinturón</div>
                <div class="ps-belt-bar"><div class="ps-belt-fill"></div></div>
                <div class="ps-belt-pct">68%</div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </section>
  </div>

  <!-- ══ FEATURES ══ -->
  <section class="section" style="border-top:1px solid var(--border);">
    <div class="container">
      <p class="section-eyebrow reveal">Funcionalidades</p>
      <h2 class="section-title reveal">Todo lo que necesitas.<br>En un solo lugar.</h2>
      <p class="section-sub reveal">Diseñado para el atleta serio. Construido para durar.</p>

      <div class="features-grid">

        <div class="feat-card reveal reveal-delay-1" style="--feat-color:#C41A1A">
          <div class="feat-icon">📋</div>
          <div class="feat-title">Diario de sesiones</div>
          <div class="feat-desc">Registra cada entrenamiento con técnicas, rounds, sparring y notas. Tu historial completo, siempre a mano.</div>
        </div>

        <div class="feat-card reveal reveal-delay-2" style="--feat-color:#3b82f6">
          <div class="feat-icon">📊</div>
          <div class="feat-title">Estadísticas avanzadas</div>
          <div class="feat-desc">Gráficas semanales y mensuales de tu progreso. Descubre tus patrones y optimiza tu entrenamiento.</div>
        </div>

        <div class="feat-card reveal reveal-delay-3" style="--feat-color:#f59e0b">
          <div class="feat-icon">🥋</div>
          <div class="feat-title">Rango y cinturón</div>
          <div class="feat-desc">Sigue tu progreso hacia el siguiente nivel. Hitos, logros y validación directa de tu coach.</div>
        </div>

        <div class="feat-card reveal reveal-delay-4" style="--feat-color:#10b981">
          <div class="feat-icon">🎯</div>
          <div class="feat-title">Panel del coach</div>
          <div class="feat-desc">Gestiona todos tus atletas desde un único panel. Asigna sesiones, revisa progreso y comunícate en tiempo real.</div>
        </div>

        <div class="feat-card reveal reveal-delay-5" style="--feat-color:#8b5cf6">
          <div class="feat-icon">💪</div>
          <div class="feat-title">Biometría & peso</div>
          <div class="feat-desc">Control completo de tu cuerpo. Hidratación, recorte de peso y evolución física con gráficas detalladas.</div>
        </div>

        <div class="feat-card reveal reveal-delay-6" style="--feat-color:#C41A1A">
          <div class="feat-icon">📅</div>
          <div class="feat-title">Periodización</div>
          <div class="feat-desc">Planifica ciclos completos de entrenamiento. Semanas base, carga y descarga para rendir en competición.</div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══ QUOTE ══ -->
  <div class="quote-section">
    <div class="reveal">
      <p class="quote-text">
        "Un hombre fuerte no es violento.<br>
        Es <em>peligroso.</em> Y un hombre peligroso<br>
        que elige proteger es el más necesario que existe."
      </p>
      <p class="quote-author">Élite Marcial</p>
    </div>
  </div>

  <!-- ══ CTA FINAL ══ -->
  <section class="cta-section">
    <div class="container" style="max-width:640px;">
      <h2 class="cta-title reveal">Próximamente.<br>Sé el primero.</h2>
      <p class="cta-sub reveal">Apúntate a la lista. Sin spam — solo el aviso el día que abramos acceso.</p>

      <div class="reveal">
        <div class="cta-form" id="ctaForm">
          <input type="email" id="ctaEmail" placeholder="tu@email.com" autocomplete="email"
            style="flex:1;background:var(--card2);border:1.5px solid var(--border2);border-radius:14px;padding:14px 18px;color:#fff;font-size:15px;font-family:inherit;font-weight:500;outline:none;transition:border-color 0.2s;"
            onfocus="this.style.borderColor='#C41A1A'" onblur="this.style.borderColor='var(--border2)'">
          <button class="btn-primary" onclick="submitEmail('ctaEmail','ctaForm','ctaSuccess','ctaHint')">Avisarme</button>
        </div>
        <p class="cta-hint" id="ctaHint">Sin spam. Solo el aviso cuando abramos.</p>
        <p class="form-success" id="ctaSuccess">✅ Apuntado. Te avisamos en cuanto abramos.</p>
      </div>

      <div class="social reveal">
        <a href="https://www.instagram.com/elitemarcial" target="_blank" rel="noopener">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          @elitemarcial
        </a>
        <a href="https://www.tiktok.com/@elitemarcial" target="_blank" rel="noopener">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>
          @elitemarcial
        </a>
      </div>
    </div>
  </section>

  <!-- ══ FOOTER ══ -->
  <footer class="footer">
    &copy; {{ 'now' | date: '%Y' }} Élite Marcial — Todos los derechos reservados.
  </footer>

  <!-- ══ PASSWORD MODAL ══ -->
  <button class="pw-trigger" onclick="openPw()">🔒 Acceso</button>

  <div class="pw-modal" id="pwModal">
    <div class="pw-box">
      <div class="pw-header">
        <h3>Acceso privado</h3>
        <button class="pw-close" onclick="closePw()">&times;</button>
      </div>
      {% form 'storefront_password' %}
        <input type="password" name="password" placeholder="Contraseña de la tienda" autofocus>
        <button type="submit" class="btn-primary">Entrar</button>
      {% endform %}
    </div>
  </div>

  <script>
    // ── Scroll reveal ──
    var revealEls = document.querySelectorAll('.reveal');
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });
    revealEls.forEach(function(el) { observer.observe(el); });

    // Trigger hero elements immediately
    setTimeout(function() {
      document.querySelectorAll('.hero .reveal, .hero-right .reveal').forEach(function(el) {
        el.classList.add('visible');
      });
    }, 80);

    // ── Email submit ──
    function submitEmail(inputId, formId, successId, hintId) {
      var input = document.getElementById(inputId);
      var email = input.value.trim();
      if (!email || !email.includes('@')) { input.focus(); return; }
      fetch('/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'form_type=customer&utf8=✓&contact[email]=' + encodeURIComponent(email) + '&contact[tags]=newsletter,app-waitlist'
      }).finally(function() {
        document.getElementById(formId).style.display = 'none';
        if (hintId) { var h = document.getElementById(hintId); if(h) h.style.display = 'none'; }
        document.getElementById(successId).style.display = 'block';
      });
    }

    ['heroEmail','ctaEmail'].forEach(function(id) {
      var el = document.getElementById(id);
      if (el) el.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') el.closest('.form-row, .cta-form').querySelector('button').click();
      });
    });

    // ── Password modal ──
    function openPw() { document.getElementById('pwModal').classList.add('open'); }
    function closePw() { document.getElementById('pwModal').classList.remove('open'); }
    document.getElementById('pwModal').addEventListener('click', function(e) {
      if (e.target === this) closePw();
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closePw();
    });
  </script>

</body>
</html>
