<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Élite Marcial — El Diario de Entrenamiento</title>
  <meta name="description" content="El diario de entrenamiento para artes marciales más completo. Sesiones, estadísticas, cinturón, biometría y coach en una sola app.">
  {{ content_for_header }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --red:#C41A1A;--gold:#f59e0b;
      --bg:#050505;--card:#0e0e0e;
      --border:#1e1e1e;--text:#f0f0f0;--muted:#888;
    }
    html{scroll-behavior:smooth}
    body{background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;-webkit-font-smoothing:antialiased;overflow-x:hidden}

    /* subtle grid */
    body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
      background-image:linear-gradient(rgba(255,255,255,.015) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.015) 1px,transparent 1px);
      background-size:64px 64px}

    /* glow */
    body::after{content:'';position:fixed;top:-200px;left:-200px;width:800px;height:800px;
      background:radial-gradient(circle,rgba(196,26,26,.08) 0%,transparent 70%);
      pointer-events:none;z-index:0}

    .wrap{position:relative;z-index:1;max-width:1100px;margin:0 auto;padding:0 24px}

    /* ── ANNOUNCE BAR ── */
    .bar{background:var(--red);text-align:center;padding:10px 16px;font-size:13px;font-weight:600;letter-spacing:.03em;position:sticky;top:0;z-index:100}
    .bar a{color:#fff;text-decoration:none;border:1px solid rgba(255,255,255,.5);border-radius:20px;padding:3px 12px;margin-left:12px;font-size:12px}
    .bar a:hover{background:rgba(255,255,255,.15)}

    /* ── NAV ── */
    nav{border-bottom:1px solid var(--border);padding:18px 0}
    .nav-inner{display:flex;align-items:center;justify-content:space-between}
    .logo{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:22px;letter-spacing:.06em;text-transform:uppercase;color:#fff;text-decoration:none}
    .logo span{color:var(--red)}
    .nav-btn{background:transparent;border:1px solid var(--border);color:var(--muted);padding:8px 18px;border-radius:6px;font-size:13px;font-weight:500;cursor:pointer;transition:all .2s}
    .nav-btn:hover{border-color:#444;color:#fff}

    /* ── HERO ── */
    .hero{padding:90px 0 70px}
    .hero-grid{display:grid;grid-template-columns:1fr 400px;gap:64px;align-items:center}
    @media(max-width:860px){.hero-grid{grid-template-columns:1fr;text-align:center}}
    .eyebrow{font-size:12px;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:var(--red);margin-bottom:20px}
    h1{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:clamp(52px,6vw,84px);line-height:1;letter-spacing:-.01em;margin-bottom:24px}
    h1 span{color:var(--red)}
    .hero-sub{font-size:17px;color:var(--muted);line-height:1.65;max-width:480px;margin-bottom:36px}
    @media(max-width:860px){.hero-sub{margin:0 auto 36px}}
    .btn-row{display:flex;gap:12px;flex-wrap:wrap}
    @media(max-width:860px){.btn-row{justify-content:center}}
    .btn-primary{background:var(--red);color:#fff;padding:14px 28px;border-radius:8px;font-weight:700;font-size:15px;text-decoration:none;transition:background .2s;white-space:nowrap}
    .btn-primary:hover{background:#a81515}
    .btn-ghost{border:1px solid var(--border);color:var(--muted);padding:14px 24px;border-radius:8px;font-weight:500;font-size:15px;text-decoration:none;transition:all .2s;white-space:nowrap}
    .btn-ghost:hover{border-color:#444;color:#fff}
    /* phone */
    .phone-box{position:relative;display:flex;justify-content:center}
    @media(max-width:860px){.phone-box{margin-top:48px}}
    .phone-glow{position:absolute;inset:-40px;background:radial-gradient(ellipse at center,rgba(196,26,26,.18) 0%,transparent 70%);pointer-events:none}
    .phone-img{width:260px;border-radius:44px;display:block;box-shadow:0 40px 80px rgba(0,0,0,.7),0 0 0 1px rgba(255,255,255,.05)}

    /* ── FEATURES ── */
    .features{padding:60px 0;border-top:1px solid var(--border)}
    .section-title{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(36px,4vw,52px);text-align:center;margin-bottom:48px}
    .section-title span{color:var(--red)}
    .feat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
    @media(max-width:700px){.feat-grid{grid-template-columns:1fr}}
    .feat-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:28px 24px}
    .feat-icon{font-size:28px;margin-bottom:14px}
    .feat-title{font-weight:700;font-size:15px;margin-bottom:8px}
    .feat-desc{font-size:14px;color:var(--muted);line-height:1.6}

    /* ── VIDEO ── */
    .video-section{padding:60px 0;border-top:1px solid var(--border)}
    .video-grid{display:grid;grid-template-columns:1fr 280px;gap:60px;align-items:center;max-width:900px;margin:0 auto}
    @media(max-width:700px){.video-grid{grid-template-columns:1fr;text-align:center}}
    .video-text h2{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(34px,4vw,50px);margin-bottom:16px}
    .video-text p{font-size:15px;color:var(--muted);line-height:1.65;margin-bottom:24px}
    .video-bullets{list-style:none;display:flex;flex-direction:column;gap:10px}
    .video-bullets li{font-size:14px;color:var(--muted);display:flex;gap:10px;align-items:flex-start}
    .video-bullets li::before{content:'→';color:var(--red);font-weight:700;flex-shrink:0}
    @media(max-width:700px){.video-bullets{align-items:center}}
    .phone-frame{width:280px;border-radius:44px;overflow:hidden;border:1.5px solid #1e1e1e;box-shadow:0 40px 80px rgba(0,0,0,.6);background:#000}
    .phone-frame video{width:100%;display:block}
    @media(max-width:700px){.phone-frame{margin:32px auto 0}}

    /* ── PRICING ── */
    .pricing{padding:60px 0;border-top:1px solid var(--border)}
    .pricing-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
    @media(max-width:900px){.pricing-grid{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:500px){.pricing-grid{grid-template-columns:1fr}}
    .plan{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:28px 22px;display:flex;flex-direction:column;gap:0;position:relative}
    .plan.featured{border-color:var(--red);box-shadow:0 0 0 1px var(--red)}
    .plan-badge{position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:var(--red);color:#fff;font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:3px 12px;border-radius:20px;white-space:nowrap}
    .plan-name{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:20px;text-transform:uppercase;letter-spacing:.04em;margin-bottom:6px}
    .plan-price{font-size:32px;font-weight:800;margin-bottom:4px}
    .plan-price span{font-size:14px;font-weight:400;color:var(--muted)}
    .plan-desc{font-size:13px;color:var(--muted);margin-bottom:20px;line-height:1.5}
    .plan-divider{height:1px;background:var(--border);margin:16px 0}
    .plan-features{list-style:none;display:flex;flex-direction:column;gap:9px;flex:1;margin-bottom:24px}
    .plan-features li{font-size:13px;color:var(--muted);display:flex;gap:8px;align-items:flex-start}
    .plan-features li::before{content:'✓';color:var(--gold);font-weight:700;flex-shrink:0}
    .plan-cta{display:block;text-align:center;padding:12px;border-radius:8px;font-weight:700;font-size:14px;text-decoration:none;transition:all .2s;margin-top:auto}
    .plan-cta.red{background:var(--red);color:#fff}
    .plan-cta.red:hover{background:#a81515}
    .plan-cta.outline{border:1px solid var(--border);color:var(--muted)}
    .plan-cta.outline:hover{border-color:#444;color:#fff}
    .plan-cta.gold{background:var(--gold);color:#000}
    .plan-cta.gold:hover{background:#d97706}

    /* ── FOOTER ── */
    footer{border-top:1px solid var(--border);padding:32px 0;text-align:center;font-size:13px;color:var(--muted)}

    /* ── PASSWORD MODAL ── */
    .pw-trigger{position:fixed;bottom:24px;right:24px;z-index:200;background:rgba(14,14,14,.95);border:1px solid var(--border);border-radius:12px;padding:10px 18px;font-size:13px;font-weight:600;color:var(--muted);cursor:pointer;backdrop-filter:blur(12px);transition:all .2s}
    .pw-trigger:hover{border-color:#444;color:#fff}
    .pw-overlay{display:none;position:fixed;inset:0;z-index:300;background:rgba(0,0,0,.85);backdrop-filter:blur(8px);align-items:center;justify-content:center}
    .pw-overlay.open{display:flex}
    .pw-box{background:#0e0e0e;border:1px solid var(--border);border-radius:16px;padding:40px 36px;width:100%;max-width:400px;margin:16px}
    .pw-box h3{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:24px;margin-bottom:8px}
    .pw-box p{font-size:14px;color:var(--muted);margin-bottom:24px}
    .pw-box input{width:100%;background:#111;border:1px solid var(--border);border-radius:8px;color:#fff;padding:12px 14px;font-size:15px;margin-bottom:12px}
    .pw-box input:focus{outline:none;border-color:#444}
    .pw-box button[type=submit]{width:100%;background:var(--red);color:#fff;border:none;border-radius:8px;padding:14px;font-size:15px;font-weight:700;cursor:pointer}
    .pw-box button[type=submit]:hover{background:#a81515}
    .pw-close{position:absolute;top:16px;right:16px;background:none;border:none;color:var(--muted);font-size:22px;cursor:pointer;line-height:1}
  </style>
</head>
<body>

<!-- ANNOUNCE BAR -->
<div class="bar">
  🔴 Acceso anticipado abierto — Plazas de Fundador limitadas
  <a href="#precios">Asegurar plaza →</a>
</div>

<!-- NAV -->
<nav>
  <div class="wrap nav-inner">
    <a href="#" class="logo">Élite<span>Marcial</span></a>
    <button class="nav-btn" onclick="openPw()">Acceder →</button>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="wrap">
    <div class="hero-grid">
      <div>
        <p class="eyebrow">// Diario de entrenamiento marcial</p>
        <h1>El arma que le<br>faltaba al<br><span>guerrero</span> moderno.</h1>
        <p class="hero-sub">Registra cada sesión. Visualiza tu progreso. Entrena con un coach que te conoce de verdad.</p>
        <div class="btn-row">
          <a href="https://buy.stripe.com/cNi4gy3JQ0av3yg7Ll2Ji02" class="btn-primary">Asegurar plaza fundador →</a>
          <a href="#precios" class="btn-ghost">Ver planes</a>
        </div>
      </div>
      <div class="phone-box">
        <div class="phone-glow"></div>
        <img class="phone-img"
          src="https://cdn.shopify.com/s/files/1/1049/1966/2933/files/inicio_sesion-portrait.png?v=1782086074"
          alt="Élite Marcial App">
      </div>
    </div>
  </div>
</section>

<!-- FEATURES -->
<section class="features">
  <div class="wrap">
    <h2 class="section-title">Todo lo que necesita<br>un <span>atleta serio.</span></h2>
    <div class="feat-grid">
      <div class="feat-card">
        <div class="feat-icon">📋</div>
        <div class="feat-title">Diario de sesiones</div>
        <div class="feat-desc">Registra técnicas, finalizaciones, notas y sensaciones. Tu historial completo en un solo lugar.</div>
      </div>
      <div class="feat-card">
        <div class="feat-icon">📊</div>
        <div class="feat-title">Estadísticas reales</div>
        <div class="feat-desc">Dashboards de rendimiento, progresión de cinturón, biometría y balance de finalizaciones.</div>
      </div>
      <div class="feat-card">
        <div class="feat-icon">🥋</div>
        <div class="feat-title">Coach personalizado</div>
        <div class="feat-desc">Tu entrenador asigna periodización, revisa tus métricas y se comunica contigo desde su panel.</div>
      </div>
    </div>
  </div>
</section>

<!-- VIDEO -->
<section class="video-section">
  <div class="wrap">
    <div class="video-grid">
      <div class="video-text">
        <p class="eyebrow">// Ve la app en acción</p>
        <h2>Así se ve<br>por dentro.</h2>
        <p>Diseñada para atletas que entrenan de verdad. Simple en el día a día, profunda en los datos.</p>
        <ul class="video-bullets">
          <li>Control de hidratación y recorte de peso</li>
          <li>Sesiones con técnicas y finalizaciones</li>
          <li>Estado físico y periodización del coach</li>
        </ul>
      </div>
      <div class="phone-frame">
        <video src="https://cdn.shopify.com/videos/c/o/v/6dfd37da9e274ebb9c3d9b92163f53e9.mp4"
          autoplay muted loop playsinline></video>
      </div>
    </div>
  </div>
</section>

<!-- PRICING -->
<section class="pricing" id="precios">
  <div class="wrap">
    <h2 class="section-title">Elige tu <span>plan.</span></h2>
    <div class="pricing-grid">

      <!-- FREE -->
      <div class="plan">
        <div class="plan-name">Free</div>
        <div class="plan-price">0€ <span>/ siempre</span></div>
        <div class="plan-desc">Para conocer la app sin compromiso.</div>
        <div class="plan-divider"></div>
        <ul class="plan-features">
          <li>Diario de sesiones básico</li>
          <li>Hasta 10 registros al mes</li>
          <li>Estadísticas limitadas</li>
        </ul>
        <a href="https://cosmic-dodol-39da77.netlify.app" class="plan-cta outline">Empezar gratis</a>
      </div>

      <!-- VITALICIO -->
      <div class="plan featured">
        <div class="plan-badge">⚡ Fundador</div>
        <div class="plan-name">Vitalicio</div>
        <div class="plan-price">499€</div>
        <div class="plan-desc">Precio de lanzamiento. Acceso completo para siempre.</div>
        <div class="plan-divider"></div>
        <ul class="plan-features">
          <li>Todo lo del plan Coach</li>
          <li>Sin pagos recurrentes</li>
          <li>Precio especial fundadores</li>
          <li>Acceso a futuras funciones</li>
        </ul>
        <a href="https://buy.stripe.com/cNi4gy3JQ0av3yg7Ll2Ji02" class="plan-cta red">Asegurar plaza →</a>
      </div>

      <!-- COACH MENSUAL -->
      <div class="plan">
        <div class="plan-name">Coach Mensual</div>
        <div class="plan-price">19€ <span>/ mes</span></div>
        <div class="plan-desc">Precio lanzamiento. Cancela cuando quieras.</div>
        <div class="plan-divider"></div>
        <ul class="plan-features">
          <li>App completa sin límites</li>
          <li>Panel de coach</li>
          <li>Periodización y métricas</li>
          <li>Chat coach-atleta</li>
        </ul>
        <a href="https://buy.stripe.com/14AfZgeou2iD5God5F2Ji00" class="plan-cta outline">Activar mensual →</a>
      </div>

      <!-- COACH ANUAL -->
      <div class="plan">
        <div class="plan-name">Coach Anual</div>
        <div class="plan-price">190€ <span>/ año</span></div>
        <div class="plan-desc">Precio lanzamiento. Ahorra 2 meses frente al mensual.</div>
        <div class="plan-divider"></div>
        <ul class="plan-features">
          <li>Todo del plan mensual</li>
          <li>Facturación anual</li>
          <li>Ahorro garantizado</li>
          <li>Soporte prioritario</li>
        </ul>
        <a href="https://buy.stripe.com/cNieVcdkq5uP8SA1mX2Ji01" class="plan-cta gold">Activar anual →</a>
      </div>

    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="wrap">
    &copy; 2026 &mdash; Elite Marcial. Todos los derechos reservados.
  </div>
</footer>

<!-- PASSWORD TRIGGER -->
<button class="pw-trigger" onclick="openPw()">🔐 Ya tengo acceso</button>

<!-- PASSWORD MODAL -->
<div class="pw-overlay" id="pwOverlay">
  <div class="pw-box" style="position:relative">
    <button class="pw-close" onclick="closePw()">×</button>
    <h3>Acceso privado</h3>
    <p>Introduce la contraseña para entrar a la tienda.</p>
    {% form 'storefront_password' %}
      {{ form.errors | default_errors }}
      <input type="password" name="password" placeholder="Contraseña" autocomplete="current-password">
      <button type="submit">Entrar →</button>
    {% endform %}
  </div>
</div>

<!-- Required by Shopify -->
<div aria-hidden="true" style="display:none;position:absolute;width:0;height:0;overflow:hidden">{{ content_for_layout }}</div>

<script>
  function openPw(){document.getElementById('pwOverlay').classList.add('open')}
  function closePw(){document.getElementById('pwOverlay').classList.remove('open')}
  document.getElementById('pwOverlay').addEventListener('click',function(e){if(e.target===this)closePw()});
  document.addEventListener('keydown',function(e){if(e.key==='Escape')closePw()});
</script>

</body>
</html>
